# O que é: Configuração global do git aplicada a todos os repositórios da máquina.
# Como usar: inclua no seu ~/.gitconfig:
#   [include]
#       path = ~/dotfiles/git/.gitconfig
# Ou aplique diretamente: cp ~/dotfiles/git/.gitconfig ~/.gitconfig
# Ajuste name e email antes de usar.

[user]
    name  = Seu Nome
    email = seu@email.com

[core]
    editor         = vim
    autocrlf       = input
    excludesfile   = ~/dotfiles/git/.gitignore_global

[pull]
    rebase = false

[push]
    default          = current
    autoSetupRemote  = true

[merge]
    ff = false

[alias]
    st      = status
    sw      = switch
    br      = branch
    lg      = log --oneline --graph --decorate --all
    undo    = reset --soft HEAD~1
    aliases = config --get-regexp alias

# ----------------------------------------------------------------------------
# Multiplas contas GitHub na mesma maquina, usando `gh` via SSH
# ----------------------------------------------------------------------------
# Problema: o SSH escolhe a chave pelo HOST. Como todas as contas ficam em
# github.com, `git@github.com` so consegue usar UMA chave -> conflito.
#
# Solucao: a conta principal usa o host padrao (github.com); cada conta extra
# ganha um ALIAS de host no ~/.ssh/config (mesmo HostName, chave diferente), e
# o git redireciona os repos daquela conta para o alias via `insteadOf`.
# Assim `gh repo clone <owner>/<repo>` (que sempre emite git@github.com:...)
# passa a usar a chave certa de cada conta automaticamente.
#
# 1) ~/.ssh/config  (uma chave por conta; gere com `ssh-keygen -t ed25519`):
#
#      # conta principal -> host padrao
#      Host github.com
#        HostName github.com
#        User git
#        IdentityFile ~/.ssh/id_ed25519_conta1
#        IdentitiesOnly yes
#
#      # conta secundaria -> alias (repita o bloco para cada conta extra)
#      Host github-conta2
#        HostName github.com
#        User git
#        IdentityFile ~/.ssh/id_ed25519_conta2
#        IdentitiesOnly yes
#
#    Adicione cada chave PUBLICA na conta correspondente (Settings > SSH keys,
#    ou `gh ssh-key add <arquivo.pub>` com a conta certa ativa) e teste:
#      ssh -T git@github.com      # -> Hi <conta1>
#      ssh -T git@github-conta2   # -> Hi <conta2>
#
# 2) Uma regra `insteadOf` por conta extra (descomente e troque owner/alias).
#    Redireciona os repos do dono <owner-conta2> para o alias github-conta2:
#
#      [url "git@github-conta2:<owner-conta2>/"]
#          insteadOf = git@github.com:<owner-conta2>/
#
# Uso e verificacao:
#   gh repo clone <owner>/<repo>
#   git -C <repo> ls-remote --get-url   # mostra git@<host-ou-alias>:<owner>/...
#
# Observacao (repos privados): antes de clonar, deixe a conta dona ATIVA com
#   `gh auth switch`, pois o `gh` consulta a API com o token da conta ativa
#   antes de iniciar o clone (a chave SSH so cuida do transporte do git).
