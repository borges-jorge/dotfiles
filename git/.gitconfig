# O que é: Configuração global do git aplicada a todos os repositórios da máquina.
# Como usar: inclua no seu ~/.gitconfig:
#   [include]
#       path = ~/dotfiles/git/.gitconfig
# Ou aplique diretamente: cp ~/dotfiles/git/.gitconfig ~/.gitconfig
# Ajuste name e email antes de usar.

[user]
    name  = Seu Nome
    email = seu@email.com

[core]
    editor         = vim
    autocrlf       = input
    excludesfile   = ~/dotfiles/git/.gitignore_global

[pull]
    rebase = false

[push]
    default          = current
    autoSetupRemote  = true

[merge]
    ff = false

[alias]
    st      = status
    sw      = switch
    br      = branch
    lg      = log --oneline --graph --decorate --all
    undo    = reset --soft HEAD~1
    aliases = config --get-regexp alias
